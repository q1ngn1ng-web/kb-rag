# =============================================================================
# individual-knowledge-base 环境变量示例
# =============================================================================
# 复制此文件为 .env 并填入真实密钥：
#     cp .env.example .env
#
# 加载优先级：shell env > .env > config.yaml
# 也就是说，若已在 ~/.bashrc 设置了同名变量，.env 中的值不会生效。
#
# .env 已在 .gitignore 中，不会被提交。

# LLM（DeepSeek 提供商）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Embedding（阿里云 DashScope）
DASHSCOPE_API_KEY=sk-your-dashscope-key

# MinerU OCR 服务
MINERU_API_KEY=eyJ-your-mineru-jwt

# MCP Server 鉴权（可选，配了 kb serve 才会校验）
# KB_MCP_API_KEY=your-mcp-api-key